# ── Aurora PostgreSQL (AWS) ─────────────────────────────────────────────────
# Get this from your Aurora cluster's connection details in AWS Console
# Format: postgresql://username:password@cluster-endpoint:5432/database_name
DATABASE_URL=postgresql://postgres:your-password@your-aurora-cluster.cluster-abc123.us-east-1.rds.amazonaws.com:5432/secondbrain

# ── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Get this from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (Embeddings) ──────────────────────────────────────────────────────
# Used for text-embedding-3-small (1536-dim vectors stored in pgvector)
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Vercel Deployment ────────────────────────────────────────────────────────
# Set automatically by Vercel. Only needed for local testing.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
